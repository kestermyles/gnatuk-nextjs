# Resend API key — get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Form sender. Must match the Resend-verified sending subdomain exactly —
# bare `gnatuk.com` will be rejected because that's not the verified domain.
# The subdomain `send.gnatuk.com` is the one Resend authenticates against.
FROM_EMAIL=GNAT UK <noreply@send.gnatuk.com>

# Primary recipient (TO)
CONTACT_EMAIL=nick@gnatuk.com

# CC recipient
CC_EMAIL=office@gnatuk.com

# BCC recipient for lead-flow visibility
BCC_EMAIL=keith@ci-media.co.uk

# Public env (safe to expose)
NEXT_PUBLIC_SITE_URL=https://www.gnatuk.com
NEXT_PUBLIC_GTM_ID=GTM-5RHLSCR

# Cloudflare Turnstile (optional spam protection on the contact form).
# Setting both keys enables verification; leaving them unset skips it entirely.
# Get keys from https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Sanity CMS — content moves into here once the project is set up.
# 1. Create a free project at https://www.sanity.io/manage
# 2. Copy the project ID and dataset ("production" by default)
# 3. Create an API token at https://www.sanity.io/manage/project/<id>/api/tokens
#    - Read token (Viewer) → SANITY_API_READ_TOKEN (used for draft preview)
#    - Editor token         → SANITY_API_WRITE_TOKEN (only used to run the migration)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=
