# Resend API key — get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Form sender (must be a verified domain in Resend)
FROM_EMAIL=GNAT UK Website <noreply@gnatuk.com>

# Primary recipient (TO)
CONTACT_EMAIL=nick@gnatuk.com

# CC recipient
CC_EMAIL=office@gnatuk.com

# BCC recipient for lead-flow visibility
BCC_EMAIL=keith@ci-media.co.uk

# Public env (safe to expose)
NEXT_PUBLIC_SITE_URL=https://www.gnatuk.com
NEXT_PUBLIC_GTM_ID=GTM-5RHLSCR

# Cloudflare Turnstile (optional spam protection on the contact form).
# Setting both keys enables verification; leaving them unset skips it entirely.
# Get keys from https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
